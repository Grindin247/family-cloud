# Family-Cloud configuration
# Copy to .env and edit.

# The base DNS suffix used for all apps.
# Example: family.callender  -> keycloak.family.callender, nextcloud.family.callender, ...
FAMILY_DOMAIN=family.example

# LAN IP of the host running docker (used for CoreDNS hosts entries).
LAN_IP=192.168.1.27

# Timezone
TZ=America/New_York

# Core network
FAMILYNET_SUBNET=172.20.0.0/24
TRAEFIK_IP=172.20.0.10
COREDNS_IP=172.20.0.11
NEXTCLOUD_AIO_IP=172.20.0.12

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_REALM=familycloud

# OIDC clients
OIDC_CLIENT_SECRET=CHANGE_ME
NEXTCLOUD_OIDC_CLIENT_SECRET=CHANGE_ME
FORWARD_AUTH_COOKIE_SECRET=CHANGE_ME
LLDAP_JWT_SECRET=CHANGE_ME
LLDAP_ADMIN_PASSWORD=CHANGE_ME

# Keycloak <-> LLDAP groups mapper (optional; defaults match typical LLDAP LDAP trees)
LLDAP_GROUPS_DN=ou=groups,dc=example,dc=com
LLDAP_GROUP_OBJECT_CLASSES=groupOfNames
LLDAP_GROUP_NAME_ATTR=cn
LLDAP_GROUP_MEMBER_ATTR=member
LLDAP_GROUP_MEMBERSHIP_ATTR_TYPE=DN
LLDAP_GROUP_MEMBERSHIP_USER_LDAP_ATTR=uid
LLDAP_GROUPS_MAPPER_MODE=READ_ONLY

# Nextcloud AIO (initial admin)
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME
NEXTCLOUD_MCP_BASE_IMAGE=ghcr.io/cbcoutinho/nextcloud-mcp-server@sha256:a48f8f30bd7a5bc4d102e95ab0acca445a8969da460285926053805a83dbbf56
NEXTCLOUD_MCP_ENABLED=false
NEXTCLOUD_MCP_PORT=8002
NEXTCLOUD_MCP_TRANSPORT=streamable-http
NEXTCLOUD_MCP_AUTH_MODE=basic
NEXTCLOUD_MCP_PUBLIC_URL=
NEXTCLOUD_READY_TAG_NAME=ready
NEXTCLOUD_MCP_ENABLE_DOCUMENT_PROCESSING=true
NEXTCLOUD_MCP_DOCUMENT_PROCESSOR=unstructured
NEXTCLOUD_MCP_ENABLE_UNSTRUCTURED=true
NEXTCLOUD_MCP_UNSTRUCTURED_API_URL=http://unstructured:8000
NEXTCLOUD_MCP_UNSTRUCTURED_TIMEOUT=120
NEXTCLOUD_MCP_UNSTRUCTURED_STRATEGY=auto
NEXTCLOUD_MCP_UNSTRUCTURED_LANGUAGES=eng
UNSTRUCTURED_IMAGE=downloads.unstructured.io/unstructured-io/unstructured-api:latest
FILE_AGENT_FAMILY_ID=2
FILE_AGENT_ACTOR=
FILE_API_PORT=8070
FILE_API_BASE_URL=http://127.0.0.1:8070/v1
HOME_PORTAL_FILE_API_BASE_URL=http://file-api:8000/v1
FILE_DISCOVERY_FAMILY_IDS=2
FILE_DISCOVERY_ROOTS=/Notes
NEXTCLOUD_MCP_URL=http://127.0.0.1:8002/mcp
TASK_AGENT_DECISION_API_BASE_URL=http://decision-api:8000/v1
TASK_AGENT_VIKUNJA_URL=http://vikunja:3456
TASK_AGENT_VIKUNJA_API_PREFIX=/api/v1
TASK_AGENT_OPS_ENABLED=true
TASK_AGENT_HYGIENE_STALE_DAYS=14
TASK_AGENT_HYGIENE_MEMBER_OVERLOAD_OPEN_TASKS=12
FAMILY_EVENT_API_BASE_URL=http://family-event-api:8000/v1
FAMILY_EVENT_API_PORT=8010
FAMILY_EVENT_POSTGRES_DB=family_event_service
FAMILY_EVENT_POSTGRES_USER=family_event_user
FAMILY_EVENT_POSTGRES_PASSWORD=CHANGE_ME
FAMILY_EVENT_INTERNAL_ADMIN_TOKEN=CHANGE_ME

# Task tracking (Vikunja) - optional profile (ops)
VIKUNJA_DB_USER=vikunja
VIKUNJA_DB_PASSWORD=CHANGE_ME
VIKUNJA_DB_NAME=vikunja
VIKUNJA_JWT_SECRET=CHANGE_ME
VIKUNJA_ENABLE_REGISTRATION=false
VIKUNJA_MCP_PYPI_VERSION=0.9.3
VIKUNJA_MCP_URL=http://vikunja:3456

# Vikunja LDAP (LLDAP)
VIKUNJA_LDAP_ENABLED=false
VIKUNJA_LDAP_HOST=ldap
VIKUNJA_LDAP_PORT=3890
VIKUNJA_LDAP_BASEDN=dc=example,dc=com
VIKUNJA_LDAP_USERFILTER="(&(objectClass=inetOrgPerson)(|(uid=%[1]s)(mail=%[1]s)))"
VIKUNJA_LDAP_BINDDN=uid=admin,ou=people,dc=example,dc=com
VIKUNJA_LDAP_BINDPASSWORD=CHANGE_ME
VIKUNJA_LDAP_USETLS=false
VIKUNJA_LDAP_ATTRIBUTE_USERNAME=uid
VIKUNJA_LDAP_ATTRIBUTE_EMAIL=mail
VIKUNJA_LDAP_ATTRIBUTE_DISPLAYNAME=cn

# Decision system (optional profile "decision")
DECISION_POSTGRES_DB=decision_system
DECISION_POSTGRES_USER=decision_user
DECISION_POSTGRES_PASSWORD=CHANGE_ME
DECISION_JWT_SECRET=CHANGE_ME
DECISION_INTERNAL_ADMIN_TOKEN=CHANGE_ME
DECISION_KEYCLOAK_BASE_URL=http://keycloak:8080
DECISION_KEYCLOAK_SYNC_CLIENT_ID=decision-system-sync
DECISION_KEYCLOAK_SYNC_CLIENT_SECRET=CHANGE_ME
DECISION_KEYCLOAK_SYNC_GROUP_SUFFIX=_family
DECISION_LLM_PROVIDER=mock
DECISION_LLM_MODEL=gpt-5.2
DECISION_OPENAI_API_KEY=
NOTE_EMBEDDING_MODEL=text-embedding-3-small
DECISION_BUDGET_DEFAULT_QUARTERLY_ALLOCATION=100
DECISION_BUDGET_ROLLOVER_PERCENT=0

# WireGuard remote access (optional profile "infra")
WIREGUARD_PUBLIC_HOST=
WIREGUARD_SERVER_PORT=51820
WIREGUARD_VPN_SUBNET=10.77.0.0/24
WIREGUARD_SERVER_VPN_IP=10.77.0.1/24
WIREGUARD_LAN_SUBNET=192.168.1.0/24
WIREGUARD_DNS=192.168.1.52
WIREGUARD_CLIENT_ALLOWED_IPS=192.168.1.0/24,10.77.0.0/24
WIREGUARD_PERSISTENT_KEEPALIVE=25
WIREGUARD_MTU=1420
WIREGUARD_POSTROUTING_INTERFACE=eth0
WIREGUARD_PUID=1000
WIREGUARD_PGID=1000

# TLS / certificates
# If true, first-run will generate a local wildcard cert for *.${FAMILY_DOMAIN}
GENERATE_LOCAL_WILDCARD_CERT=true
CERT_DAYS=3650
